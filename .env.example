# Database
POSTGRES_USER=neuroflow
POSTGRES_PASSWORD=         # Required: strong random password
POSTGRES_DB=neuroflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=              # Required: full connection string (postgresql://user:pass@host:port/db)

# Redis
REDIS_PASSWORD=            # Required: strong random password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=                 # Required: full connection string (redis://:pass@host:port/0)

# LLM Providers
OPENAI_API_KEY=            # Required
ANTHROPIC_API_KEY=         # Optional: for Anthropic provider
DEFAULT_LLM_MODEL=gpt-4o-mini

# MLflow
MLFLOW_TRACKING_URI=       # Required: PostgreSQL URL for MLflow backend (e.g., http://mlflow:5000)

# Security
JWT_SECRET_KEY=            # Required: 256-bit random key (openssl rand -hex 32)
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
PLUGIN_SECRETS_KEY=        # Required: Fernet key (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")

# Telemetry
JAEGER_HOST=jaeger
JAEGER_PORT=4317
OTEL_EXPORTER_OTLP_ENDPOINT= # Optional: OTLP collector endpoint
SENTRY_DSN=                  # Optional: Sentry error tracking

# App
ENVIRONMENT=               # Required: development | staging | production
LOG_LEVEL=                 # Optional: DEBUG | INFO | WARNING (default: INFO)
API_URL=                   # Required: public URL of the API for frontend
