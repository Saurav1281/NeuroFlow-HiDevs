{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Queries Per Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(neuroflow_queries_total[1m])) * 60", "legendFormat": "Global" },
        { "expr": "sum by (status) (rate(neuroflow_queries_total[1m])) * 60", "legendFormat": "{{status}}" }
      ]
    },
    {
      "title": "Retrieval Latency (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(neuroflow_retrieval_latency_seconds_bucket[5m])))", "legendFormat": "P95 Latency" }
      ]
    },
    {
      "title": "Generation Latency (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(neuroflow_generation_latency_seconds_bucket[5m])))", "legendFormat": "P95 Latency" }
      ]
    },
    {
      "title": "LLM Cost (Estimated USD/hr)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(neuroflow_llm_cost_usd[1h])) * 3600" }
      ]
    },
    {
      "title": "Circuit Breakers Open",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        { "expr": "neuroflow_circuit_breakers_open" }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["neuroflow", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "NeuroFlow — System Overview",
  "uid": "neuroflow-system",
  "version": 1
